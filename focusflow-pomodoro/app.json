{
  "expo": {
    "name": "FocusFlow",
    "slug": "focusflow-pomodoro",
    "description": "AI-powered Pomodoro scheduler with heuristic-driven daily focus optimization",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "focusflow",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.focusflow.app",
      "buildNumber": "1.0.0"
    },
    "android": {
      "package": "com.focusflow.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#f7f9fb",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#f7f9fb",
          "dark": {
            "backgroundColor": "#f7f9fb"
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0f661028-12a9-4165-93f9-9b51de523e4b"
      }
    },
    "owner": "hunhow"
  }
}
